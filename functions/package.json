{
  "name": "functions",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": "22"
  },
  "main": "lib/index.js",
  "scripts": {
    "build": "tsc -p tsconfig.json && node esbuild.config.js",
    "dev": "node esbuild.config.js --watch",
    "serve": "npm run build && firebase emulators:start --only functions,firestore,auth",
    "test": "vitest run",
    "lint": "eslint src --ext .ts"
  },
  "dependencies": {
    "firebase-admin": "^13.0.0",
    "firebase-functions": "^6.0.1",
    "express": "^4.21.0",
    "stripe": "^17.3.0",
    "undici": "^7.2.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "esbuild": "^0.24.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.4"
  }
}
